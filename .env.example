# Directory containing the externally maintained repositories read by the host MCP process.
REPOS_DIR=/absolute/path/to/repositories

MYSQL_DATABASE=agent_platform
MYSQL_USER=agent
MYSQL_PASSWORD=agent
MYSQL_ROOT_PASSWORD=local-root-password
MYSQL_DSN=agent:agent@tcp(127.0.0.1:3306)/agent_platform?parseTime=true&charset=utf8mb4&loc=UTC
REDIS_URL=redis://127.0.0.1:6379/0
LLM_BASE_URL=
LLM_API_KEY=
# Model identifier supported by the configured Gateway, for example gpt-4.1-mini.
LLM_MODEL=internal-default
WORKSPACE_MCP_URL=http://127.0.0.1:8081/mcp
WORKER_ID=worker-local

# Structured zap logs: JSON to stdout and daily rotating files under LOG_DIR.
LOG_DIR=logs
LOG_LEVEL=info
LOG_MAX_AGE_DAYS=14

# Optional Docker build proxy. On macOS, scripts/up.sh defaults this to port 7890.
# Docker image pulls themselves use the Docker Desktop/Engine proxy configuration.
DOCKER_PROXY_URL=
DOCKER_ALL_PROXY_URL=

# Optional host dependency download proxy.
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost
